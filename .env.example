# Cloudinary Configuration
# Get these values from your Cloudinary dashboard: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name-here

# ---- Pets page (set these in Vercel project settings, not just locally) ----

# Server-side: lets /api/pets/photos list the Pets folder and
# /api/pets/sign-upload sign uploads. Never expose with a VITE_ prefix.
CLOUDINARY_API_SECRET=your-api-secret

# REQUIRED for uploads — comma-separated Google accounts allowed to upload to
# the pets collection. This is the private half of the gate; keep it out of the
# repo (set it only in Vercel). Uploads stay off until this is set.
PETS_UPLOADERS=email-one@gmail.com,email-two@gmail.com

# Google OAuth client ID for the curators' upload gate. A Web-application client
# ID is public by design, so it's committed as a default in the code (the
# Waypoints client). Only set these to OVERRIDE that default with a different
# client (Google Cloud Console → Credentials → OAuth client ID, type "Web
# application", with the site domain + http://localhost:5173 as authorized
# JavaScript origins). VITE_ for the sign-in button, plain for the server check.
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
