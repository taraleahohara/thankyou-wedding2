# Cloudinary Configuration
# Get these values from your Cloudinary dashboard: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name-here

# ---- Pets page (set these in Vercel project settings, not just locally) ----

# Server-side: lets /api/pets/photos list the Pets folder and
# /api/pets/sign-upload sign uploads. Never expose with a VITE_ prefix.
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth client ID for the curators' upload gate (Google Cloud Console →
# Credentials → OAuth client ID, type "Web application", with the site domain
# and http://localhost:5173 as authorized JavaScript origins).
# The same value goes in both: VITE_ for the sign-in button, plain for the
# server-side audience check.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Comma-separated Google accounts allowed to upload to the pets collection.
PETS_UPLOADERS=taraleahohara@gmail.com,dan@example.com
