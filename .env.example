# Cloudinary Configuration
# Get these values from your Cloudinary dashboard: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name-here

# Optional: If you need to use API key and secret for uploads (usually not needed for just displaying images)
# VITE_CLOUDINARY_API_KEY=your-api-key
# VITE_CLOUDINARY_API_SECRET=your-api-secret

